# Unreal Engine plugin .gitignore

# Build / compile output
Binaries/
Intermediate/
Build/

# Editor-generated data
Saved/
DerivedDataCache/
DDC/

# Project files generated by UnrealBuildTool
*.VC.db
*.opensdf
*.opendb
*.sdf
*.sln
*.suo
*.xcodeproj
*.xcworkspace

# OS / IDE
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python caches (Content/Python)
__pycache__/
*.py[cod]
*.pyo

# Crash reports / logs
*.log
*.tmp
